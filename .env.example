# ============================================================================
# Querei configuration. Copy this file to `.env` and fill in your key(s).
#   cp .env.example .env
# ============================================================================

# --- THE ONLY KEY YOU NEED FOR THE DEFAULT (Gemini) SETUP -------------------
# Get a free key at https://aistudio.google.com/apikey
# This single key powers chat, search embeddings, AND video analysis.
GEMINI_API_KEY=

# --- Provider selection -----------------------------------------------------
# Swap any of these and restart — no code changes needed.
# LLM_PROVIDER:        gemini | openai | anthropic   (chat + tool-calling)
# EMBEDDING_PROVIDER:  gemini | openai               (search embeddings)
# VISUAL_ANALYZER:     gemini | keyframes | none     (pipeline video analysis)
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
VISUAL_ANALYZER=gemini

# --- Other providers (only needed if you select them above) -----------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Model overrides (optional; sensible defaults are baked in) -------------
# GEMINI_CHAT_MODEL=gemini-2.5-flash   # free tier ~20 requests/day; paid key removes cap
# GEMINI_EMBED_MODEL=gemini-embedding-001
# GEMINI_VIDEO_MODEL=gemini-2.5-flash
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_EMBED_MODEL=text-embedding-3-large
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5

# --- Search tuning (optional) -----------------------------------------------
# SEARCH_DEFAULT_K=5
# SEARCH_VECTOR_WEIGHT=0.7          # 0 = pure keyword, 1 = pure semantic
# SEARCH_SYNTHESIZE_REASONS=true    # one-line "why it matched" per result
