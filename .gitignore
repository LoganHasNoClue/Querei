# ===== Secrets — NEVER commit =====
.env
.env.*
!.env.example

# ===== Python =====
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# ===== Node / frontend build =====
web/node_modules/
web/dist/

# ===== Local agent/editor config =====
.claude/
*.log

# ===== macOS =====
.DS_Store

# ===== Built data =====
# Raw source videos and the vector index stay OUT of git (videos are large /
# private; the Chroma index is rebuilt automatically on first boot from
# descriptions.json). The corpus metadata + thumbnails ARE tracked so the
# private repo can deploy your videos to the hosted site.
data/raw/
data/chroma/

# Keep the committed sample corpus + its thumbnails:
!data/sample/
!data/sample/**
